---
import '@fontsource-variable/outfit';
import { Icon } from 'astro-icon/components';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sunny Kolattukudy — Platform builder and developer experience engineer." />
    <title>Sunny Kolattukudy</title>
    <link rel="icon" href="/images/favicon.svg" type="image/svg+xml" />
  </head>

  <body>

    <!-- ───── HERO ───── -->
    <header class="hero">
      <div class="hero-inner">
        <div class="hero-accent">
          <div class="accent-bar"></div>
          <p class="eyebrow">Platform Builder · Developer Experience · Columbus, OH</p>
        </div>
        <h1 class="hero-name">
          <span class="name-line">Sunny</span>
          <span class="name-line">Kolattukudy</span>
        </h1>
        <p class="tagline">
          I build agentic engineering systems — code review pipelines, plugin marketplaces,
          and the scaffolding that makes teams move faster without losing control.
        </p>
      </div>
    </header>

    <!-- ───── STACK ───── -->
    <section class="stack-section" aria-label="Tech stack">
      <ul class="chip-list" role="list">
        <li class="chip"><Icon name="simple-icons:dotnet" class="chip-icon" />.NET / C#</li>
        <li class="chip"><Icon name="simple-icons:blazor" class="chip-icon" />Blazor WASM</li>
        <li class="chip"><Icon name="simple-icons:typescript" class="chip-icon" />TypeScript</li>
        <li class="chip"><Icon name="simple-icons:amazon" class="chip-icon" />AWS Bedrock</li>
        <li class="chip"><Icon name="simple-icons:githubactions" class="chip-icon" />GitHub Actions</li>
        <li class="chip"><Icon name="simple-icons:microsoftazure" class="chip-icon" />Azure</li>
        <li class="chip"><Icon name="simple-icons:anthropic" class="chip-icon" />Anthropic / Claude</li>
        <li class="chip"><Icon name="simple-icons:openai" class="chip-icon" />OpenAI / Codex</li>
      </ul>
    </section>

    <!-- ───── NOW ───── -->
    <section class="section now-section" aria-labelledby="now-heading">
      <p class="eyebrow" id="now-heading">Now</p>
      <div class="now-grid" role="list">
        <div class="now-card now-card--wide" role="listitem">
          <span class="now-label">Building</span>
          <ul class="project-list">
            <li>
              <a href="https://kolatts.github.io/pncli" class="project-link" target="_blank" rel="noopener noreferrer">
                PNCLI
              </a>
            </li>
            <li>
              <a href="https://verifiable.com/" class="project-link" target="_blank" rel="noopener noreferrer">
                AI Native Agentic Workflows
              </a>
            </li>
            <li>
              <a href="https://app.imagile.dev" class="project-link" target="_blank" rel="noopener noreferrer">
                Imagile B2B Platform
              </a>
            </li>
          </ul>
        </div>
        <div class="now-card" role="listitem">
          <span class="now-label">Reading</span>
          <span class="now-value">The Simple Path to Wealth · The Startup Owner's Manual · Romans</span>
        </div>
        <div class="now-card" role="listitem">
          <span class="now-label">Listening</span>
          <span class="now-value">High Fade · Angine de Poitrine · Carpenter Brut · At the Gates</span>
        </div>
      </div>
    </section>

    <!-- ───── EXPERIENCE ───── -->
    <section class="section exp-section" aria-labelledby="exp-heading">
      <p class="eyebrow" id="exp-heading">Experience</p>
      <ol class="exp-list">

        <li class="exp-role">
          <div class="exp-header">
            <span class="exp-company">Verifiable</span>
            <span class="exp-meta">Staff Engineer · Developer Experience Guild Leader · 2025 – Present</span>
          </div>
          <ul class="exp-bullets">
            <li>Built an AI-powered code review pipeline on AWS Bedrock — cut PR review time by 30+ minutes per pull request and standardized CI/CD practices org-wide via a reusable GitHub Actions workflow library.</li>
            <li>Prototyped Source Warden: an autonomous ops pipeline that ingests Datadog alerts and opens remediation PRs without human triage — proving end-to-end AI ownership of an ops workflow.</li>
            <li>Architected an AI-native local dev platform in .NET and Blazor WASM with automatic data seeding, integrated E2E tests, and self-healing infrastructure so AI coding tools operate against a fully realistic environment.</li>
          </ul>
        </li>

        <li class="exp-role">
          <div class="exp-header">
            <span class="exp-company">Arcoro</span>
            <span class="exp-meta">Principal Software Engineer · 2021 – 2025</span>
          </div>
          <ul class="exp-bullets">
            <li>Pioneered Arcoro Hub — now the company's central product platform — a technical vision to scale 10x in .NET, Blazor Hybrid WASM, and .NET MAUI with a live sync bridge to legacy applications.</li>
            <li>Tripled feature delivery speed across all product teams by building a new SPA and API for ExakTime in Angular and .NET while preserving a seamless experience for existing users.</li>
            <li>Rewrote a bug-ridden event-driven architecture on Azure Event Hubs, Functions, and Storage — 98% performance improvement and stopped customer data loss.</li>
          </ul>
        </li>

        <li class="exp-role">
          <div class="exp-header">
            <span class="exp-company">PNC Bank</span>
            <span class="exp-meta">Principal Software Engineer · 2016 – 2021</span>
          </div>
          <ul class="exp-bullets">
            <li>Led rewrites of two legacy institutional asset management systems into .NET — 86%+ performance improvement on workloads handling millions of dollars per hour, passing internal audit.</li>
            <li>Increased QA deployment frequency from once per month to 4+ per day by building CI/CD pipelines with Azure DevOps and IBM UrbanCode Deploy.</li>
            <li>Mentored a developer focused on code quality and simplicity — who now leads a team of 7 on the same applications.</li>
          </ul>
        </li>

      </ol>
    </section>

    <!-- ───── LINKS ───── -->
    <section class="section links-section" aria-labelledby="links-heading">
      <p class="eyebrow" id="links-heading">Find me</p>
      <nav class="pill-row" aria-label="External links">
        <a class="pill" href="https://github.com/kolatts" target="_blank" rel="noopener noreferrer"><Icon name="simple-icons:github" class="pill-icon" />GitHub</a>
        <a class="pill" href="https://linkedin.com/in/sunnykolattukudy" target="_blank" rel="noopener noreferrer"><Icon name="simple-icons:linkedin" class="pill-icon" />LinkedIn</a>
        <a class="pill" href="https://imagile.dev" target="_blank" rel="noopener noreferrer">Imagile</a>
        <a class="pill" href="https://app.imagile.dev" target="_blank" rel="noopener noreferrer">Projects</a>
        <a class="pill pill--outline" href="/SunnyKolattukudyResume.pdf" download>Resume ↓</a>
      </nav>
    </section>

    <!-- ───── TRIPTYCH ───── -->
    <section class="triptych-section" aria-label="Background">
      <div class="triptych-wrap">
        <img
          src="/images/pictures.png"
          alt="Three portraits: Sunny as a physician in a white coat, as a metal vocalist on stage, and as a software engineer in front of code"
          class="triptych-img"
          loading="eager"
          decoding="async"
        />
        <div class="triptych-labels" aria-hidden="true">
          <span>Medicine</span>
          <span>Heavy Metal</span>
          <span>Software</span>
        </div>
        <div class="triptych-narrative">
          <p>The medicine chapter was about learning how to help people well. Case Western Reserve University and Cleveland Clinic's Lerner College of Medicine gave that a rigorous foundation: understand the problem fully before acting, and know that getting it wrong has real consequences for real people.</p>
          <p>Co-founding <a href="https://www.youtube.com/@DEADIRONvideos" class="narrative-link" target="_blank" rel="noopener noreferrer">Deadiron</a>, a melodic thrash metal band, added something different — the experience of building something creative with a group of people where everyone has to be fully invested for it to work. A band that's clicking is a good model for what a high-functioning team looks like.</p>
          <p>Software turned out to be where both of those things fit — the problems are technical, but the work is still about helping people and building things together. That became the foundation for a decade of engineering across finance, HR tech, and healthtech.</p>
          <p>That experience runs through a consistent pattern: modernizing solutions, building collaborative teams, and leveling up organizations with cutting-edge engineering practices so that every member can contribute and grow.</p>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <p>&copy; 2026 Sunny Kolattukudy</p>
    </footer>

  </body>
</html>

<style>
  /* ── Variables ── */
  :root {
    --teal-50:  #E1F5EE;
    --teal-200: #5DCAA5;
    --teal-400: #1D9E75;
    --teal-600: #0F6E56;
    --teal-900: #04342C;
    --ink:      #0D0D0D;
    --surface:  #F7F7F5;
    --muted:    #6B7280;

    --text-xs:   0.75rem;
    --text-sm:   0.875rem;
    --text-base: 1rem;
    --text-lg:   1.25rem;
    --text-hero: clamp(3rem, 10vw, 9rem);
  }

  /* ── Reset & base ── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    background: url('/images/hero-bg.png') center / cover fixed;
  }

  body {
    font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif;
    font-size: var(--text-base);
    color: var(--ink);
    background: transparent;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Eyebrow ── */
  .eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 400;
  }

  /* ── Hero ── */
  .hero {
    min-height: 75svh;
    display: flex;
    align-items: center;
    padding: clamp(3rem, 8vw, 6rem) clamp(1.5rem, 6vw, 6rem) clamp(2rem, 5vw, 4rem);
    background: transparent;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    max-width: 900px;
    width: 100%;
  }

  .hero-accent {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .accent-bar {
    width: 48px;
    height: 4px;
    background: var(--teal-400);
    border-radius: 2px;
  }

  /* Scroll-driven parallax — CSS only, no JS */
  @supports (animation-timeline: scroll()) {
    .hero-accent {
      animation: parallax-up linear both;
      animation-timeline: scroll();
      animation-range: 0 40vh;
    }
    @keyframes parallax-up {
      to {
        transform: translateY(-60px);
        opacity: 0.4;
      }
    }
  }

  .hero-name {
    display: flex;
    flex-direction: column;
    font-size: var(--text-hero);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  @media (min-width: 640px) {
    :root {
      --text-hero: clamp(4rem, 12vw, 9rem);
    }
  }

  .name-line {
    display: block;
  }

  .tagline {
    font-size: var(--text-lg);
    color: var(--muted);
    line-height: 1.6;
    max-width: 520px;
  }

  /* ── Sections shared ── */
  .section {
    padding: clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 6vw, 6rem);
  }

  .section > .eyebrow {
    margin-bottom: 1.5rem;
  }

  /* ── Stack ── */
  .stack-section {
    background: transparent;
    padding: 0 clamp(1.5rem, 6vw, 6rem) clamp(1.5rem, 3vw, 2.5rem);
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    list-style: none;
  }

  .chip {
    border: 1px solid var(--teal-200);
    color: var(--teal-600);
    background: transparent;
    border-radius: 999px;
    padding: 6px 16px;
    font-size: 0.85rem;
    font-family: inherit;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .chip-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: var(--teal-400);
  }

  /* ── Experience ── */
  .exp-section {
    background: rgba(255, 255, 255, 0.78);
  }

  .exp-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .exp-role {
    display: grid;
    gap: 0.75rem;
    padding: 1.25rem;
    margin: -1.25rem;
    border-radius: 12px;
    border: 1.5px solid transparent;
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
    cursor: default;
  }

  .exp-role:hover {
    background: rgba(29, 158, 117, 0.04);
    border-color: var(--teal-200);
  }

  @media (min-width: 640px) {
    .exp-role {
      grid-template-columns: 260px 1fr;
      gap: 0 2.5rem;
    }
  }

  .exp-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.1rem;
  }

  .exp-company {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--ink);
    transition: color 0.2s ease;
  }

  .exp-role:hover .exp-company {
    color: var(--teal-600);
  }

  .exp-meta {
    font-size: var(--text-xs);
    color: var(--muted);
    line-height: 1.5;
  }

  .exp-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .exp-bullets li {
    font-size: var(--text-sm);
    color: var(--ink);
    line-height: 1.65;
    padding-left: 1rem;
    position: relative;
    transition: color 0.2s ease;
  }

  .exp-role:hover .exp-bullets li {
    color: #1a1a1a;
  }

  .exp-bullets li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--teal-400);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .exp-role:hover .exp-bullets li::before {
    color: var(--teal-600);
    transform: translateX(2px);
  }

  /* ── Now ── */
  .now-section {
    background: rgba(247, 247, 245, 0.82);
  }

  .now-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media (min-width: 640px) {
    .now-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .now-card {
    background: rgba(255, 255, 255, 0.85);
    border-radius: 12px;
    border: 0.5px solid #E5E7EB;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .now-card--wide {
    grid-column: 1 / -1;
  }

  .now-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .now-value {
    font-size: var(--text-base);
    color: var(--ink);
    line-height: 1.4;
  }

  .project-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  @media (min-width: 640px) {
    .project-list {
      flex-direction: row;
      gap: 1.5rem;
    }
  }

  .project-link {
    color: var(--teal-400);
    text-decoration: none;
    font-size: var(--text-base);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: color 0.15s ease;
  }

  .project-link::after {
    content: '↗';
    font-size: 0.75em;
    opacity: 0.7;
  }

  .project-link:hover {
    color: var(--teal-600);
  }

  /* ── Links ── */
  .links-section {
    background: rgba(247, 247, 245, 0.82);
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: var(--teal-400);
    color: #fff;
    border-radius: 999px;
    padding: 8px 20px;
    font-size: 0.85rem;
    font-family: inherit;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .pill:hover,
  .pill:focus-visible {
    background: var(--teal-600);
    outline: none;
  }

  .pill:focus-visible {
    box-shadow: 0 0 0 3px var(--teal-50);
  }

  .pill--outline {
    background: transparent;
    color: var(--teal-600);
    border: 1.5px solid var(--teal-400);
  }

  .pill--outline:hover,
  .pill--outline:focus-visible {
    background: var(--teal-50);
  }

  .pill-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.85);
  }

  /* ── Triptych ── */
  .triptych-section {
    background: var(--teal-900);
    padding: clamp(2.5rem, 5vw, 4.5rem) clamp(1.5rem, 6vw, 6rem);
  }

  .triptych-wrap {
    max-width: 900px;
    margin: 0 auto;
  }

  .triptych-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
    object-fit: cover;
  }

  .triptych-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 1rem;
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--teal-200);
    opacity: 0.7;
  }

  .triptych-narrative {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 680px;
  }

  .triptych-narrative p {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.75;
  }

  .narrative-link {
    color: var(--teal-200);
    text-decoration: underline;
    text-decoration-color: rgba(93, 202, 165, 0.4);
    text-underline-offset: 3px;
    transition: color 0.15s ease;
  }

  .narrative-link:hover {
    color: #fff;
  }

  .triptych-narrative p:first-child {
    color: rgba(255, 255, 255, 0.92);
    font-size: var(--text-lg);
    font-weight: 400;
  }

  /* ── Footer ── */
  .site-footer {
    padding: 2rem clamp(1.5rem, 6vw, 6rem);
    background: var(--teal-900);
    border-top: 0.5px solid rgba(255, 255, 255, 0.08);
  }

  .site-footer p {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.04em;
  }
</style>

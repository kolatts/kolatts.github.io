---
import '@fontsource-variable/outfit';
import { Icon } from 'astro-icon/components';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sunny Kolattukudy — Platform builder and developer experience engineer." />
    <title>Sunny Kolattukudy</title>
    <link rel="icon" href="/images/favicon.svg" type="image/svg+xml" />
  </head>

  <body>

    <!-- ───── HERO ───── -->
    <header class="hero">
      <img
        src="/images/pictures.png"
        alt=""
        class="hero-portrait"
        data-parallax="0.16"
        loading="eager"
        decoding="async"
        aria-hidden="true"
      />
      <div class="hero-rail hero-rail--one" data-parallax="-0.08" aria-hidden="true"></div>
      <div class="hero-rail hero-rail--two" data-parallax="0.22" aria-hidden="true"></div>
      <div class="hero-inner" data-parallax="-0.04">
        <div class="hero-kicker">
          <span>Platform Builder</span>
          <span>Developer Experience</span>
          <span>Columbus, OH</span>
        </div>
        <h1 class="hero-name">
          <span class="name-line">Sunny</span>
          <span class="name-line">Kolattukudy</span>
        </h1>
        <p class="tagline">
          I build agentic engineering systems — code review pipelines, plugin marketplaces,
          and the scaffolding that makes teams move faster without losing control.
          I mentor engineers and level up the people around me.
        </p>
        <nav class="hero-actions" aria-label="Primary links">
          <a class="action action--primary" href="/SunnyKolattukudyResume.pdf" download>Resume</a>
          <a class="action" href="https://github.com/kolatts" target="_blank" rel="noopener noreferrer"><Icon name="simple-icons:github" class="action-icon" />GitHub</a>
          <a class="action" href="https://linkedin.com/in/sunnyjk" target="_blank" rel="noopener noreferrer"><Icon name="simple-icons:linkedin" class="action-icon" />LinkedIn</a>
          <a class="action" href="https://imagile.dev" target="_blank" rel="noopener noreferrer">Imagile</a>
          <a class="action" href="https://app.imagile.dev" target="_blank" rel="noopener noreferrer">Projects</a>
        </nav>
      </div>
      <div class="hero-panel" data-parallax="-0.12" aria-hidden="true">
        <span class="panel-label">Current Focus</span>
        <span class="panel-title">AI-native engineering systems</span>
        <span class="panel-copy">Turning local dev, review, and operations into faster feedback loops.</span>
      </div>
    </header>

    <!-- ───── STACK ───── -->
    <section class="stack-section" aria-label="Tech stack">
      <ul class="chip-list" role="list">
        <li class="chip"><Icon name="simple-icons:dotnet" class="chip-icon" />.NET / C#</li>
        <li class="chip"><Icon name="simple-icons:blazor" class="chip-icon" />Blazor WASM</li>
        <li class="chip"><Icon name="simple-icons:typescript" class="chip-icon" />TypeScript</li>
        <li class="chip"><Icon name="simple-icons:amazon" class="chip-icon" />AWS Bedrock</li>
        <li class="chip"><Icon name="simple-icons:githubactions" class="chip-icon" />GitHub Actions</li>
        <li class="chip"><Icon name="simple-icons:microsoftazure" class="chip-icon" />Azure</li>
        <li class="chip"><Icon name="simple-icons:anthropic" class="chip-icon" />Claude Code</li>
        <li class="chip"><Icon name="simple-icons:openai" class="chip-icon" />OpenAI Codex</li>
      </ul>
    </section>

    <!-- ───── NOW ───── -->
    <section class="section now-section" aria-labelledby="now-heading">
      <p class="eyebrow" id="now-heading">Now</p>
      <div class="now-grid" role="list">
        <div class="now-card now-card--wide" role="listitem">
          <span class="now-label">Building</span>
          <ul class="project-list">
            <li>
              <a href="https://kolatts.github.io/pncli" class="project-link" target="_blank" rel="noopener noreferrer">
                PNCLI
              </a>
            </li>
            <li>
              <a href="https://verifiable.com/" class="project-link" target="_blank" rel="noopener noreferrer">
                AI Native Agentic Workflows
              </a>
            </li>
            <li>
              <a href="https://app.imagile.dev" class="project-link" target="_blank" rel="noopener noreferrer">
                Imagile B2B Platform
              </a>
            </li>
          </ul>
        </div>
        <div class="now-card" role="listitem">
          <span class="now-label">Reading</span>
          <span class="now-value">Getting to Yes · Matthew · Startup Owner's Manual</span>
        </div>
        <div class="now-card" role="listitem">
          <span class="now-label">Listening</span>
          <span class="now-value">Bethel Music · Yellow Stitches · Kalmah</span>
        </div>
      </div>
    </section>

    <!-- ───── EXPERIENCE ───── -->
    <section class="section exp-section" aria-labelledby="exp-heading">
      <p class="eyebrow" id="exp-heading">Experience</p>
      <ol class="exp-list">

        <li class="exp-role">
          <div class="exp-header">
            <span class="exp-company">Verifiable</span>
            <span class="exp-meta">Staff Engineer · Developer Experience Guild Leader · 2025 – Present</span>
          </div>
          <ul class="exp-bullets">
            <li>Built an AI-powered code review pipeline on AWS Bedrock — cut PR review time by 30+ minutes per pull request and standardized CI/CD practices org-wide via a reusable GitHub Actions workflow library.</li>
            <li>Prototyped Source Warden: an autonomous ops pipeline that ingests Datadog alerts and opens remediation PRs without human triage — proving end-to-end AI ownership of an ops workflow.</li>
            <li>Architected an AI-native local dev platform in .NET and Blazor WASM with automatic data seeding, integrated E2E tests, and self-healing infrastructure so AI coding tools operate against a fully realistic environment.</li>
          </ul>
        </li>

        <li class="exp-role">
          <div class="exp-header">
            <span class="exp-company">Arcoro</span>
            <span class="exp-meta">Principal Software Engineer · 2021 – 2025</span>
          </div>
          <ul class="exp-bullets">
            <li>Pioneered Arcoro Hub — now the company's central product platform — a technical vision to scale 10x in .NET, Blazor Hybrid WASM, and .NET MAUI with a live sync bridge to legacy applications.</li>
            <li>Tripled feature delivery speed across all product teams by building a new SPA and API for ExakTime in Angular and .NET while preserving a seamless experience for existing users.</li>
            <li>Rewrote a bug-ridden event-driven architecture on Azure Event Hubs, Functions, and Storage — 98% performance improvement and stopped customer data loss.</li>
          </ul>
        </li>

        <li class="exp-role">
          <div class="exp-header">
            <span class="exp-company">PNC Bank</span>
            <span class="exp-meta">Principal Software Engineer · 2016 – 2021</span>
          </div>
          <ul class="exp-bullets">
            <li>Led rewrites of two legacy institutional asset management systems into .NET — 86%+ performance improvement on workloads handling millions of dollars per hour, passing internal audit.</li>
            <li>Increased QA deployment frequency from once per month to 4+ per day by building CI/CD pipelines with Azure DevOps and IBM UrbanCode Deploy.</li>
            <li>Mentored a developer focused on code quality and simplicity — who now leads a team of 7 on the same applications.</li>
          </ul>
        </li>

      </ol>
    </section>

    <!-- ───── BACKGROUND ───── -->
    <section class="triptych-section" aria-label="Background">
      <div class="triptych-wrap">
        <p class="background-tagline">From medicine to music to software.</p>
        <div class="triptych-narrative">
          <p>The medicine chapter was about learning how to help people well. Case Western Reserve University and Cleveland Clinic's Lerner College of Medicine gave that a rigorous foundation: understand the problem fully before acting, and know that getting it wrong has real consequences for real people.</p>
          <p>Co-founding <a href="https://www.youtube.com/@DEADIRONvideos" class="narrative-link" target="_blank" rel="noopener noreferrer">Deadiron</a>, a melodic thrash metal band, added something different — the experience of building something creative with a group of people where everyone has to be fully invested for it to work. A band that's clicking is a good model for what a high-functioning team looks like.</p>
          <p>Software turned out to be where both of those things fit — the problems are technical, but the work is still about helping people and building things together. That became the foundation for a decade of engineering across finance, HR tech, and health credentialing automation.</p>
          <p>That experience runs through a consistent pattern: modernizing solutions, building collaborative teams, and leveling up organizations with cutting-edge engineering practices so that every member can contribute and grow.</p>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <p>&copy; 2026 Sunny Kolattukudy</p>
    </footer>

    <script>
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const parallaxItems = Array.from(document.querySelectorAll('[data-parallax]'));

      function updateParallax() {
        if (reduceMotion.matches) return;

        const scrollY = window.scrollY;
        for (const item of parallaxItems) {
          const speed = Number(item.dataset.parallax || 0);
          item.style.setProperty('--parallax-y', `${scrollY * speed}px`);
        }
      }

      updateParallax();
      window.addEventListener('scroll', () => requestAnimationFrame(updateParallax), { passive: true });
    </script>

  </body>
</html>

<style>
  :root {
    --ink: #101416;
    --paper: #f6f2e9;
    --paper-strong: #fffaf0;
    --night: #071316;
    --night-2: #0f2426;
    --teal: #2ed3b7;
    --teal-dark: #0f816d;
    --ember: #ff6b35;
    --gold: #f5c95a;
    --plum: #6c4bd2;
    --muted: #667275;
    --line: rgba(16, 20, 22, 0.16);
    --light-line: rgba(255, 250, 240, 0.18);
    --shadow: 0 26px 70px rgba(7, 19, 22, 0.18);

    --text-xs: 0.75rem;
    --text-sm: 0.9rem;
    --text-base: 1rem;
    --text-lg: 1.22rem;
    --text-xl: 1.55rem;
    --text-hero: 4.2rem;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    background: var(--night);
  }

  body {
    font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif;
    font-size: var(--text-base);
    color: var(--ink);
    background:
      linear-gradient(180deg, rgba(7, 19, 22, 0) 0, rgba(7, 19, 22, 0) 82svh, var(--paper) 82svh),
      url('/images/hero-bg.png') center top / cover fixed;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
  }

  .eyebrow {
    color: var(--teal-dark);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero {
    min-height: 88svh;
    position: relative;
    isolation: isolate;
    display: grid;
    align-items: end;
    padding: 4.5rem 1.25rem 2rem;
    overflow: hidden;
    color: var(--paper-strong);
    background: var(--night);
  }

  .hero::before,
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .hero::before {
    background:
      linear-gradient(90deg, rgba(7, 19, 22, 0.96) 0%, rgba(7, 19, 22, 0.9) 34%, rgba(7, 19, 22, 0.42) 62%, rgba(7, 19, 22, 0.22) 100%),
      linear-gradient(0deg, rgba(7, 19, 22, 0.9) 0%, rgba(7, 19, 22, 0.04) 48%, rgba(7, 19, 22, 0.34) 100%);
  }

  .hero::after {
    opacity: 0.32;
    background:
      linear-gradient(120deg, transparent 0 28%, rgba(46, 211, 183, 0.32) 28% 29%, transparent 29% 52%, rgba(255, 107, 53, 0.36) 52% 53%, transparent 53%),
      repeating-linear-gradient(90deg, rgba(255, 250, 240, 0.12) 0 1px, transparent 1px 96px);
    mix-blend-mode: screen;
  }

  .hero-portrait {
    position: absolute;
    inset: -8%;
    z-index: 0;
    width: 116%;
    height: 116%;
    object-fit: cover;
    object-position: 76% center;
    opacity: 0.9;
    filter: saturate(1.26) contrast(1.12) brightness(1.08);
    transform: translate3d(0, var(--parallax-y, 0), 0) scale(1.02);
    will-change: transform;
  }

  .hero-rail {
    position: absolute;
    z-index: 2;
    pointer-events: none;
    transform: translate3d(0, var(--parallax-y, 0), 0) rotate(-18deg);
    will-change: transform;
  }

  .hero-rail--one {
    width: 11rem;
    height: 62svh;
    right: 19%;
    bottom: -11svh;
    border-left: 1px solid rgba(46, 211, 183, 0.5);
    border-right: 1px solid rgba(245, 201, 90, 0.36);
    background: linear-gradient(180deg, rgba(46, 211, 183, 0.18), rgba(255, 107, 53, 0.08));
  }

  .hero-rail--two {
    width: 7rem;
    height: 38svh;
    right: 6%;
    top: 12svh;
    border-left: 1px solid rgba(255, 107, 53, 0.48);
    background: linear-gradient(180deg, rgba(255, 107, 53, 0.22), transparent);
  }

  .hero-inner {
    position: relative;
    z-index: 3;
    width: min(100%, 1120px);
    margin-inline: auto;
    transform: translate3d(0, var(--parallax-y, 0), 0);
    will-change: transform;
  }

  .hero-kicker {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 1.4rem;
  }

  .hero-kicker span {
    min-height: 2rem;
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--light-line);
    border-radius: 999px;
    padding: 0.42rem 0.8rem;
    color: rgba(255, 250, 240, 0.88);
    background: rgba(7, 19, 22, 0.36);
    backdrop-filter: blur(12px);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-name {
    display: flex;
    flex-direction: column;
    max-width: 12ch;
    margin-bottom: 1.35rem;
    color: var(--paper-strong);
    font-size: var(--text-hero);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.92;
    text-shadow: 0 18px 52px rgba(0, 0, 0, 0.42);
  }

  .name-line {
    display: block;
  }

  .tagline {
    max-width: 710px;
    color: rgba(255, 250, 240, 0.84);
    font-size: var(--text-lg);
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.7rem;
  }

  .action {
    min-height: 2.7rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: 999px;
    padding: 0.72rem 1rem;
    font-family: inherit;
    font-size: var(--text-sm);
    font-weight: 800;
    text-decoration: none;
    transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, color 0.18s ease;
  }

  .action {
    border: 1px solid var(--light-line);
    color: var(--paper-strong);
    background: rgba(255, 250, 240, 0.08);
    backdrop-filter: blur(14px);
  }

  .action--primary {
    border-color: transparent;
    color: var(--night);
    background: linear-gradient(135deg, var(--gold), var(--ember));
  }

  .action:hover,
  .action:focus-visible {
    transform: translateY(-2px);
    outline: none;
  }

  .action:focus-visible,
  .project-link:focus-visible,
  .narrative-link:focus-visible {
    box-shadow: 0 0 0 3px rgba(46, 211, 183, 0.34);
  }

  .action-icon,
  .chip-icon {
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
  }

  .hero-panel {
    width: min(19rem, calc(100% - 2.5rem));
    position: absolute;
    z-index: 3;
    right: 1.25rem;
    bottom: 1.5rem;
    display: none;
    border: 1px solid var(--light-line);
    border-radius: 8px;
    padding: 1rem;
    background: rgba(7, 19, 22, 0.68);
    backdrop-filter: blur(16px);
    box-shadow: var(--shadow);
    transform: translate3d(0, var(--parallax-y, 0), 0);
    will-change: transform;
  }

  .panel-label,
  .panel-copy {
    display: block;
    color: rgba(255, 250, 240, 0.62);
    font-size: var(--text-xs);
    line-height: 1.45;
  }

  .panel-label {
    color: var(--gold);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .panel-title {
    display: block;
    margin: 0.35rem 0;
    color: var(--paper-strong);
    font-size: var(--text-lg);
    font-weight: 900;
    line-height: 1.1;
  }

  .section,
  .stack-section,
  .triptych-section,
  .site-footer {
    padding-inline: 1.25rem;
  }

  .section {
    padding-block: 3.5rem;
  }

  .section > .eyebrow {
    width: min(100%, 1120px);
    margin: 0 auto 1.4rem;
  }

  .stack-section {
    position: relative;
    z-index: 1;
    padding-block: 1.1rem;
    color: var(--paper-strong);
    background: linear-gradient(90deg, var(--night), #112f2e 52%, #341b28);
    border-block: 1px solid rgba(255, 250, 240, 0.1);
  }

  .chip-list {
    width: min(100%, 1120px);
    margin-inline: auto;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    list-style: none;
  }

  .chip {
    display: inline-flex;
    min-height: 2.15rem;
    align-items: center;
    gap: 0.45rem;
    border: 1px solid rgba(255, 250, 240, 0.18);
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    color: rgba(255, 250, 240, 0.84);
    background: rgba(255, 250, 240, 0.06);
    font-size: var(--text-sm);
    font-weight: 700;
    white-space: nowrap;
  }

  .chip-icon {
    color: var(--teal);
  }

  .now-section {
    color: var(--paper-strong);
    background:
      linear-gradient(180deg, #081618 0%, #101f22 52%, var(--night) 100%),
      url('/images/hero-bg.png') center / cover;
  }

  .now-section .eyebrow {
    color: var(--gold);
  }

  .now-grid,
  .exp-list {
    width: min(100%, 1120px);
    margin-inline: auto;
  }

  .now-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }

  .now-card {
    position: relative;
    display: flex;
    min-height: 7rem;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--light-line);
    border-radius: 8px;
    padding: 1.25rem;
    background: rgba(255, 250, 240, 0.06);
    box-shadow: 0 18px 46px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(14px);
  }

  .now-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-top: 5px solid var(--teal);
    pointer-events: none;
  }

  .now-card:nth-child(2)::before {
    border-top-color: var(--ember);
  }

  .now-card:nth-child(3)::before {
    border-top-color: var(--plum);
  }

  .now-card:nth-child(4)::before {
    border-top-color: var(--gold);
  }

  .now-label {
    color: rgba(255, 250, 240, 0.58);
    font-size: var(--text-xs);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .now-value {
    color: var(--paper-strong);
    font-size: var(--text-lg);
    font-weight: 800;
    line-height: 1.2;
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    list-style: none;
  }

  .project-link {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.35rem;
    color: var(--teal);
    font-size: var(--text-lg);
    font-weight: 900;
    line-height: 1.2;
    text-decoration: none;
  }

  .project-link::after {
    content: '↗';
    color: var(--ember);
    font-size: var(--text-sm);
  }

  .exp-section {
    color: var(--paper-strong);
    background:
      linear-gradient(180deg, rgba(7, 19, 22, 0.95), rgba(15, 36, 38, 0.97)),
      url('/images/hero-bg.png') center / cover;
  }

  .exp-section .eyebrow {
    color: var(--gold);
  }

  .exp-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    counter-reset: roles;
  }

  .exp-role {
    counter-increment: roles;
    display: grid;
    gap: 1rem;
    padding: 1.6rem 0;
    border-top: 1px solid var(--light-line);
  }

  .exp-role:last-child {
    border-bottom: 1px solid var(--light-line);
  }

  .exp-header {
    display: grid;
    gap: 0.3rem;
    align-content: start;
  }

  .exp-header::before {
    content: '0' counter(roles);
    color: var(--ember);
    font-size: var(--text-sm);
    font-weight: 900;
  }

  .exp-company {
    color: var(--paper-strong);
    font-size: var(--text-xl);
    font-weight: 900;
    line-height: 1;
  }

  .exp-meta {
    color: rgba(255, 250, 240, 0.58);
    font-size: var(--text-sm);
    line-height: 1.45;
  }

  .exp-bullets {
    display: grid;
    gap: 0.8rem;
    list-style: none;
  }

  .exp-bullets li {
    position: relative;
    padding-left: 1.15rem;
    color: rgba(255, 250, 240, 0.78);
    font-size: var(--text-base);
    line-height: 1.65;
  }

  .exp-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.68em;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--teal);
    box-shadow: 0 0 0 4px rgba(46, 211, 183, 0.14);
  }

  .triptych-section {
    padding-block: 3.75rem;
    color: var(--paper-strong);
    background: linear-gradient(135deg, #151015 0%, #0b2223 58%, #321912 100%);
  }

  .triptych-wrap {
    width: min(100%, 1120px);
    margin-inline: auto;
  }

  .background-tagline {
    max-width: 920px;
    color: var(--paper-strong);
    font-size: clamp(1.7rem, 3vw, 3.25rem);
    font-weight: 950;
    line-height: 1.02;
  }

  .triptych-narrative {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  .triptych-narrative p {
    color: rgba(255, 250, 240, 0.72);
    font-size: var(--text-base);
    line-height: 1.75;
  }

  .triptych-narrative p:first-child {
